APP_NAME="Multitenant SaaS Task Manager"
APP_ENV=local
APP_KEY=                            # Run: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development uses SQLite (default). For Docker, switch to PostgreSQL:
#
#   DB_CONNECTION=pgsql
#   DB_HOST=db            # Docker service name from docker-compose.local.yml
#   DB_PORT=5432
#   DB_DATABASE=tasksmanager
#   DB_USERNAME=your_user
#   DB_PASSWORD=your_password
#
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=tasksmanager
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Queue ────────────────────────────────────────────────────────────────────
# NotifyTaskAssignment jobs are dispatched asynchronously.
# Use the 'database' driver for local dev or switch to 'redis' in Docker:
#
#   QUEUE_CONNECTION=redis
#
QUEUE_CONNECTION=database

# ─── Cache ────────────────────────────────────────────────────────────────────
# The CachedTaskRepository decorates the Eloquent repository with per-tenant
# Redis cache keys (tenant_{id}_tasks). Switch to 'redis' for Docker:
#
#   CACHE_STORE=redis
#
CACHE_STORE=database

# ─── Redis ────────────────────────────────────────────────────────────────────
# Required when CACHE_STORE=redis or QUEUE_CONNECTION=redis.
# Docker service name: redis (from docker-compose.local.yml)
#
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1    # Use 'redis' when running inside Docker
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
# Notifications are logged by default. Replace with a real driver in production.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
